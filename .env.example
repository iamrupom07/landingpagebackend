# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require"

# Redis / BullMQ / distributed rate limits
# Required when NODE_ENV=production.
REDIS_URL="redis://localhost:6379"

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-64-char-hex-secret-here"
JWT_EXPIRES_IN="1h"

# Admin app
ADMIN_APP_URL="http://localhost:3000"
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# CORS
CORS_ORIGINS="http://localhost:3000"

# Export safeguards
MAX_EXPORT_ROWS=50000

# SMTP (Gmail example)
# SMTP_HOST, SMTP_USER, and SMTP_PASS must be set together. Leave all blank to disable emails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Business Internet <you@gmail.com>"
NOTIFICATION_EMAIL="you@gmail.com"

# Admin seed (used by npm run db:seed)
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="ChooseAStrongPassword123!"
ADMIN_NAME="Admin"
