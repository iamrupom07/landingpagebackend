generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED_WON
  CLOSED_LOST
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Lead {
  id              String     @id @default(uuid())
  businessName    String     @map("business_name")
  businessAddress String     @map("business_address")
  contactName     String     @map("contact_name")
  phone           String
  email           String
  currentProvider String     @map("current_provider")
  interestedPlan  Plan?      @map("interested_plan")
  employeeCount   Int?       @map("employee_count")
  comments        String?
  status          LeadStatus @default(NEW)
  source          String     @default("form") @map("source") // "form" | "manual"
  ipAddress       String?    @map("ip_address")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  emailLogs EmailLog[]

  @@index([status])
  @@index([createdAt])
  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "leads_created_at_id_idx")
  @@index([interestedPlan])
  @@index([interestedPlan, createdAt(sort: Desc), id(sort: Desc)], map: "leads_interested_plan_created_at_id_idx")
  @@index([source])
  @@index([source, createdAt(sort: Desc), id(sort: Desc)], map: "leads_source_created_at_id_idx")
  @@index([status, createdAt(sort: Desc), id(sort: Desc)], map: "leads_status_created_at_id_idx")
  @@map("leads")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  tokenVersion Int       @default(0) @map("token_version")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")

  passwordResetTokens PasswordResetToken[]

  @@map("admin_users")
}

model EmailLog {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  type         String
  subject      String?
  recipient    String
  status       String   @default("sent")
  errorMessage String?  @map("error_message")
  sentAt       DateTime @default(now()) @map("sent_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("email_logs")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  adminUserId String    @map("admin_user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
